# Core app
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hisarweb
PAYLOAD_SECRET=dev-payload-secret
NEXTAUTH_SECRET=dev-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
PORT=3000
HOSTNAME=0.0.0.0
DATA_DIR=./data
AUTH_TRUST_HOST=true
NEXT_TELEMETRY_DISABLED=1

# Optional local QA / automation
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001

# Optional auth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Marketing Dashboard OIDC Provider
MARKETING_DASHBOARD_ISSUER=https://marketing-dashboard-brown.vercel.app
MARKETING_DASHBOARD_CLIENT_ID=
MARKETING_DASHBOARD_CLIENT_SECRET=
MARKETING_DASHBOARD_SCOPE=openid profile email

# Optional media/email integrations
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESEND_API_KEY=

# Optional product telemetry
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Release checks
GITHUB_REPOSITORY=hisarweb/hisarweb-starter
