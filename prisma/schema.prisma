generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  domain        String?  @unique
  plan          String   @default("starter")
  status        String   @default("active")
  ownerId       String
  industry      String?
  accentColor   String   @default("#6d28d9")
  logoUrl       String?
  faviconUrl    String?
  siteName      String?
  tagline       String?
  themeMode     String   @default("system")
  fontPreset    String   @default("geist")
  customCss     String?
  gaTrackingId  String?
  defaultLocale String   @default("nl")
  extraLocales  String[]
  modules       String[]
  settings      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner    User      @relation("OrgOwner", fields: [ownerId], references: [id])
  members  User[]    @relation("OrgMembers")
  pages    Page[]
  navItems NavItem[]
  media    Media[]
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String?
  role            String   @default("admin")
  emailVerified   Boolean  @default(false)
  organizationId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ownedOrgs    Organization[] @relation("OrgOwner")
  organization Organization?  @relation("OrgMembers", fields: [organizationId], references: [id])
}

model Page {
  id              String    @id @default(cuid())
  organizationId  String
  title           String
  slug            String
  status          String    @default("draft")
  locale          String    @default("nl")
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  metaOgImage     String?
  blocks          Json      @default("[]")
  sortOrder       Int       @default(0)
  isHomePage      Boolean   @default(false)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  revisions    PageRevision[]

  @@unique([organizationId, slug, locale])
}

model NavItem {
  id             String   @id @default(cuid())
  organizationId String
  label          String
  href           String
  sortOrder      Int      @default(0)
  parentId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  parent       NavItem?     @relation("NavChildren", fields: [parentId], references: [id])
  children     NavItem[]    @relation("NavChildren")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PageRevision {
  id        String   @id @default(cuid())
  pageId    String
  blocks    Json
  createdBy String?
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model Media {
  id             String   @id @default(cuid())
  organizationId String
  filename       String
  url            String
  publicId       String?
  mimeType       String
  size           Int
  width          Int?
  height         Int?
  alt            String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
}

model WizardConfig {
  id                String   @id @default("singleton")
  siteName          String
  adminEmail        String
  adminPasswordHash String
  databaseProvider  String
  databaseUrl       String
  industry          String
  accentColor       String
  accentColorDark   String?
  logoUrl           String?
  fontPreset        String
  themeMode         String   @default("system")
  enabledModules    String[]
  socialProviders   String[]
  allowRegistration Boolean  @default(false)
  enableMagicLink   Boolean  @default(false)
  defaultLocale     String   @default("nl")
  extraLocales      String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SiteConfig {
  id            String   @id @default(cuid())
  siteName      String
  accentColor   String?
  logoUrl       String?
  themeMode     String   @default("system")
  primaryLocale String   @default("nl")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model RegistrationRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  createdAt DateTime @default(now())
}

model PasswordResetRequest {
  id        String   @id @default(cuid())
  email     String
  createdAt DateTime @default(now())
}

model UpdateLog {
  id           String   @id @default(cuid())
  version      String
  changelogUrl String?
  appliedAt    DateTime?
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  userName       String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json     @default("{}")
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId])
}

model ActiveSession {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  userAgent   String?
  ipAddress   String?
  lastActiveAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  events         String[]
  secret         String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  statusCode Int?
  success    Boolean  @default(false)
  payload    Json     @default("{}")
  response   String?
  duration   Int?
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
}
